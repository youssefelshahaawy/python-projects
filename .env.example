# Environment variables used by the email projects
# (Day 32 - Birthday Wisher, Day 33 - ISS Overhead).
#
# Copy this file to ".env" for reference, then set these as real environment
# variables in your shell before running those scripts. The code reads them
# with os.environ.get(...), so nothing secret is ever stored in the source.
#
# For Gmail, SENDER_PASSWORD must be a 16-character "App Password"
# (Google Account -> Security -> 2-Step Verification -> App passwords),
# NOT your normal account password.

SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_16_char_app_password
RECIPIENT_EMAIL=who_to_email@example.com
